---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CtaFooter from '../components/CtaFooter.astro';

const SOLUTIONS_URL = 'https://one-out-solutions.vercel.app/';

const services = [
  { img: 'https://images.unsplash.com/photo-1611532736597-de2d4265fba3?q=80&w=800&auto=format&fit=crop', title: "Identidad Visual", desc: "Logotipos, paletas de color y tipografías. Creamos la base visual que hará que tu negocio sea reconocido y recordado." },
  { img: 'https://images.unsplash.com/photo-1563986768494-4dee2763ff0f?q=80&w=800&auto=format&fit=crop', title: "Diseño UI/UX", desc: "Interfaces limpias y fáciles de usar. Diseñamos pensando en la experiencia del usuario para aumentar conversiones." },
  { img: 'https://images.unsplash.com/photo-1507238692062-5a02455ca96f?q=80&w=800&auto=format&fit=crop', title: "Sistemas de Diseño", desc: "Reglas claras y componentes reutilizables. Tu marca mantendrá una coherencia perfecta en cualquier rincón de internet." },
  { img: 'https://images.unsplash.com/photo-1558655146-d09347e92766?q=80&w=800&auto=format&fit=crop', title: "Dirección Creativa", desc: "Desde el concepto hasta la ejecución. Guiamos la visión estética para asegurar que cada pieza aporte al objetivo comercial." }
];
---
<Layout
  title="Diseño & Marca — One Out Creative"
  description="Construimos identidades y sistemas de diseño con propósito. No solo se ve bien, sino que funciona y escala."
>
  <Navbar />
  <main id="top">

    <!-- ── HERO (Creative Layout) ─────────────────────────────────── -->
    <section class="brand-hero">
      <div class="hero-container">
        <div class="hero-content">
          <div class="reveal-hidden">
            <div class="eyebrow accent" style="margin-bottom: 24px;"><span class="dot"></span>Diseño & Marca</div>
          </div>
          
          <h1 class="font-heading big-title">
            <div class="reveal-hidden" style="transition-delay: 0.1s;">Marcas que</div>
            <div class="reveal-hidden" style="transition-delay: 0.15s; margin-left: 5vw; display: flex; align-items: center; gap: 15px;">
              <div class="title-line"></div>
              <span>destacan,</span>
            </div>
            <div class="reveal-hidden" style="transition-delay: 0.2s;">
              <span style="color: var(--accent);">memorables.</span>
            </div>
          </h1>

          <div class="reveal-hidden hero-subtext" style="transition-delay: 0.3s;">
            <p>
              No hacemos logos genéricos. Construimos sistemas de identidad visual y diseño de interfaces con un propósito claro: comunicar el valor de tu negocio de forma impactante y coherente.
            </p>
          </div>
        </div>

        <div class="hero-visual">
          <div class="reveal-hidden visual-img img-1" style="transition-delay: 0.2s;">
            <img src="https://images.unsplash.com/photo-1600132806370-bf17e65e942f?q=80&w=800&auto=format&fit=crop" alt="Diseño de marca caja" loading="lazy" />
          </div>
          <div class="reveal-hidden visual-img img-2" style="transition-delay: 0.3s;">
            <img src="https://images.unsplash.com/photo-1561070791-2526d30994b5?q=80&w=600&auto=format&fit=crop" alt="Branding abstracto" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ── MANIFIESTO MARQUEE ───────────────────────────────────── -->
    <section class="manifesto-wrap">
      <div class="reveal-hidden" style="transition-delay: 0.1s;">
        <h2 class="font-heading manifesto-text">
          Menos ruido. <span style="color: transparent; -webkit-text-stroke: 1px var(--fg);">Más intención.</span> 
          Conectamos estrategia <span style="color: transparent; -webkit-text-stroke: 1px var(--accent);">con estética.</span>
        </h2>
      </div>
    </section>

    <!-- ── SERVICIOS BENTO ──────────────────────────────────────── -->
    <section class="services-section">
      <div class="services-container">
        <div class="reveal-hidden" style="margin-bottom: 48px;">
          <h2 class="font-heading" style="font-size: clamp(2rem, 4vw, 3rem); line-height: 1; margin: 0; text-transform: uppercase;">
            Nuestras especialidades
          </h2>
        </div>

        <div class="bento-grid">
          {services.map((srv, i) => (
            <div class={`reveal-hidden bento-card bento-${i}`} style={`transition-delay: ${(i * 0.1) + 0.1}s;`}>
              <div class="bento-img-wrap">
                <img src={srv.img} alt={srv.title} class="bento-img" loading="lazy" />
                <div class="bento-overlay"></div>
              </div>
              <div class="bento-content">
                <span class="font-heading bento-num">0{i + 1}</span>
                <h3 class="font-heading bento-title">{srv.title}</h3>
                <p class="bento-desc">{srv.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── GALERÍA DE ENFOQUE (Miniaturas) ──────────────────────── -->
    <section class="gallery-section">
      <div class="gallery-grid">
        <div class="reveal-hidden gal-item" style="transition-delay: 0.1s;">
          <img src="https://images.unsplash.com/photo-1626785779602-7634f1bfce3e?q=80&w=800&auto=format&fit=crop" alt="Moodboard" loading="lazy" />
          <p class="font-heading gal-caption">Moodboards & Conceptos</p>
        </div>
        <div class="reveal-hidden gal-item" style="transition-delay: 0.2s; margin-top: 10%;">
          <img src="https://images.unsplash.com/photo-1586717791821-3f44a563fa4c?q=80&w=800&auto=format&fit=crop" alt="Paletas de color" loading="lazy" />
          <p class="font-heading gal-caption">Sistemas de Color</p>
        </div>
        <div class="reveal-hidden gal-item" style="transition-delay: 0.3s;">
          <img src="https://images.unsplash.com/photo-1620324838637-29cb6baae001?q=80&w=800&auto=format&fit=crop" alt="Tipografía" loading="lazy" />
          <p class="font-heading gal-caption">Curaduría Tipográfica</p>
        </div>
      </div>
    </section>

    <!-- ── CTA FINAL ────────────────────────────────────────────── -->
    <section style="background: var(--card); padding: clamp(80px, 12vw, 130px) 24px; position: relative; overflow: hidden;">
      <div class="cta-glow"></div>
      <div style="max-width: 1000px; margin: 0 auto; text-align: center; position: relative; z-index: 2;">
        <div class="reveal-hidden">
          <div class="eyebrow accent" style="margin-bottom: 24px; justify-content: center;"><span class="dot"></span>Dale vida a tu marca</div>
        </div>
        <div class="reveal-hidden" style="transition-delay: 0.1s;">
          <h2 class="font-heading" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 0.95; text-transform: uppercase; margin: 0 0 24px;">
            El diseño no es un gasto.<br />Es una <span style="color: var(--accent);">inversión visible.</span>
          </h2>
        </div>
        <div class="reveal-hidden" style="transition-delay: 0.2s;">
          <p style="font-size: 1.1rem; color: var(--muted); font-weight: 300; max-width: 600px; margin: 0 auto 40px; line-height: 1.6;">
            Si creés que es hora de elevar la percepción de tu negocio y competir en las ligas mayores, hablemos sobre cómo podemos ayudarte.
          </p>
          <a href="https://wa.me/50689000108" target="_blank" rel="noopener noreferrer" class="btn-primary" style="padding: 1.1rem 2.4rem; font-size: 0.9rem;">
            Iniciar tu proyecto de marca
          </a>
        </div>
      </div>
    </section>

    <CtaFooter />
  </main>
</Layout>

<style>
  /* ── GLOBALES DE PÁGINA ──────────────────────────────────────── */
  .brand-hero {
    padding: clamp(120px, 15vw, 180px) 24px clamp(60px, 10vw, 100px);
    background: var(--bg);
    overflow: hidden;
  }
  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 60px;
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero-container {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .big-title {
    font-size: clamp(3.5rem, 8vw, 7.5rem);
    line-height: 0.85;
    text-transform: uppercase;
    color: var(--fg);
    margin: 0;
  }
  .title-line {
    height: 6px;
    width: clamp(40px, 8vw, 100px);
    background-color: var(--fg);
  }
  
  .hero-subtext {
    margin-top: 40px;
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    line-height: 1.7;
    color: var(--muted);
    font-weight: 300;
    max-width: 480px;
  }

  /* Imágenes del Hero tipo Collage */
  .hero-visual {
    position: relative;
    min-height: 500px;
  }
  .visual-img {
    position: absolute;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
  }
  .visual-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .visual-img:hover img {
    transform: scale(1.05);
  }
  .img-1 {
    width: 75%;
    aspect-ratio: 4/5;
    top: 0;
    right: 0;
    z-index: 1;
  }
  .img-2 {
    width: 55%;
    aspect-ratio: 1/1;
    bottom: 20px;
    left: -10%;
    z-index: 2;
    border: 4px solid var(--bg); /* Separador visual */
  }

  /* ── MANIFIESTO ───────────────────────────────────────────── */
  .manifesto-wrap {
    padding: clamp(60px, 10vw, 100px) 24px;
    background: var(--bg);
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    text-align: center;
  }
  .manifesto-text {
    font-size: clamp(2.2rem, 5vw, 4.2rem);
    line-height: 1.1;
    text-transform: uppercase;
    margin: 0;
    max-width: 1100px;
    margin: 0 auto;
    text-wrap: balance;
  }

  /* ── BENTO GRID ────────────────────────────────────────────── */
  .services-section {
    padding: clamp(80px, 12vw, 140px) 24px;
    background: var(--bg);
  }
  .services-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: minmax(300px, auto);
    }
    .bento-0 { grid-column: span 2; min-height: 400px; }
  }
  
  .bento-card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: var(--card);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 350px;
    padding: 32px;
    group: hover;
  }
  .bento-img-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .bento-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .bento-card:hover .bento-img {
    transform: scale(1.08); /* GSAP-like smooth scale */
  }
  .bento-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.4) 50%, transparent 100%);
  }

  .bento-content {
    position: relative;
    z-index: 1;
  }
  .bento-num {
    display: block;
    font-size: 1.25rem;
    color: var(--accent);
    margin-bottom: 8px;
    opacity: 0.8;
  }
  .bento-title {
    font-size: clamp(2rem, 3vw, 2.5rem);
    text-transform: uppercase;
    margin: 0 0 12px;
    line-height: 1;
  }
  .bento-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin: 0;
    max-width: 400px;
    font-weight: 300;
  }

  /* ── GALERÍA DE IMÁGENES ASIMÉTRICA ───────────────────────── */
  .gallery-section {
    padding: clamp(40px, 8vw, 80px) 24px clamp(80px, 12vw, 140px);
    background: var(--bg);
  }
  .gallery-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }
  .gal-item {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .gal-item img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    border-radius: 8px;
    filter: grayscale(20%);
    transition: filter 0.4s ease;
  }
  .gal-item:hover img {
    filter: grayscale(0%);
  }
  .gal-caption {
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
  }

  /* ── CTA GLOW ─────────────────────────────────────────────── */
  .cta-glow {
    position: absolute;
    top: -50%; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(232,119,34,0.15) 0%, transparent 60%);
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('reveal-visible');
          entry.target.classList.remove('reveal-hidden');
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
  );
  
  document.querySelectorAll('.reveal-hidden').forEach(el => observer.observe(el));
</script>