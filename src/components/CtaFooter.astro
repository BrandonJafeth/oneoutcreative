---
const year = new Date().getFullYear();
---
<section id="nosotros" style="background: var(--bg); padding-top: clamp(60px, 10vw, 120px); position: relative; overflow: hidden;">
  <div aria-hidden="true" style="position: absolute; top: -40px; left: 50%; transform: translateX(-50%); width: 700px; height: 380px; border-radius: 9999px; background: radial-gradient(ellipse, rgba(232,119,34,0.14), transparent 70%); filter: blur(60px); pointer-events: none;"></div>

  <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 2;">
    <div class="cta-editorial">
      <div>
        <div class="reveal-hidden delay-0">
          <div class="eyebrow accent">Empezá hoy</div>
        </div>
        <div class="reveal-hidden delay-1">
          <h2 class="font-heading" style="font-size: clamp(3.5rem, 8vw, 6.5rem); line-height: 0.9; letter-spacing: 0.02em; text-transform: uppercase; color: var(--fg); margin: 20px 0 0;">
            ¿Listo para<br /><span style="color: var(--accent);">crecer?</span>
          </h2>
        </div>
        <div class="reveal-hidden delay-2">
          <p style="margin-top: 24px; font-weight: 300; font-size: 1rem; color: var(--muted); max-width: 460px; line-height: 1.65; font-family: var(--font-body);">
            Hablemos de tu negocio. Sin compromiso, sin formularios interminables. Una llamada es suficiente para saber si somos el equipo que necesitás.
          </p>
        </div>
        <div class="reveal-hidden delay-3">
          <div class="flex flex-col md:flex-row gap-3 mt-9 w-full md:w-auto">
            <a href="https://wa.me/50600000000" target="_blank" rel="noopener noreferrer" class="btn-primary flex-1 md:flex-none justify-center items-center gap-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
              <span class="whitespace-nowrap">Contactar</span>
            </a>
            <a href="https://instagram.com/oneoutcreative" target="_blank" rel="noopener noreferrer" class="btn-ghost liquid-glass-strong flex-1 md:flex-none justify-center items-center gap-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
              <span class="whitespace-nowrap">Instagram</span>
            </a>
          </div>
        </div>
      </div>

      <div class="reveal-hidden delay-2">
        <div class="cta-visual" style="min-height: auto; align-items: center;">
          <div style="position: relative; z-index: 2; text-align: center;">
            <div class="cta-stat-val">300%</div>
            <div style="margin-top: 16px; font-size: 0.7rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--muted); font-weight: 500; font-family: var(--font-body);">Crecimiento promedio</div>
            <div style="margin-top: 8px; font-size: 0.7rem; color: var(--soft-text); font-weight: 300; font-family: var(--font-body);">en los primeros 6 meses</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div style="overflow: hidden; position: relative; z-index: 1; margin-top: 80px;">
    <div class="reveal-hidden delay-0">
      <div class="font-heading" aria-hidden="true" style="font-size: clamp(5rem, 22vw, 22rem); line-height: 0.85; letter-spacing: -0.01em; color: rgba(var(--fg-rgb) / 0.05); text-align: center; white-space: nowrap; text-transform: uppercase;">
        ONE OUT.
      </div>
    </div>
  </div>

  <footer class="footer-bar relative z-10 w-full max-w-[1280px] mx-auto px-6 pt-12 flex flex-col md:flex-row justify-between items-center gap-8 font-body">
    <div class="flex flex-col items-center md:flex-row md:items-center gap-4 text-center md:text-left text-[var(--soft-text)] text-[0.8rem]">
      <img src="https://res.cloudinary.com/dkwvaxxdw/image/upload/v1779290752/Logo_blanco_1_kintyq.png" alt="One Out Creative" class="flex-shrink-0" style="width: 28px; height: 28px; object-fit: contain; filter: var(--logo-filter, invert(0));" />
      <span class="max-w-[250px] md:max-w-none leading-relaxed">© {year} One Out Creative. Todos los derechos reservados.</span>
    </div>
    <div class="flex flex-wrap justify-center items-center gap-6 text-[0.8rem] text-[var(--soft-text)]">
      <a href="https://instagram.com/oneoutcreative" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--fg)] transition-colors py-2">Instagram</a>
      <span aria-hidden="true" class="opacity-40">·</span>
      <a href="https://wa.me/50600000000" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--fg)] transition-colors py-2">WhatsApp</a>
    </div>
  </footer>

</section>

<style>
  :global(.light) .footer-bar img {
    --logo-filter: invert(1);
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('reveal-visible');
        entry.target.classList.remove('reveal-hidden');
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  
  document.querySelectorAll('.reveal-hidden').forEach(el => observer.observe(el));
</script>
