---
import testimonios from '../data/testimonios.json';
const [t1raw, t2raw, t3raw] = testimonios;
const t1 = { q: t1raw.quote, n: t1raw.name, r: t1raw.role, metric: t1raw.metric };
const t2 = { q: t2raw.quote, n: t2raw.name, r: t2raw.role };
const t3 = { q: t3raw.quote, n: t3raw.name, r: t3raw.role };
---
<section id="proyectos" style="background: var(--card); padding: clamp(60px, 10vw, 120px) 24px;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; max-width: 820px; margin: 0 auto 64px;">
      <div class="reveal-hidden delay-0">
        <div class="eyebrow"><span class="dot"></span>Lo que dicen nuestros clientes</div>
      </div>
      <div class="reveal-hidden delay-1">
        <h2 class="sec-heading" style="margin-top: 14px;">Resultados que hablan solos</h2>
      </div>
    </div>

    <div class="testi-grid">
      <div class="reveal-hidden delay-0">
        <div class="liquid-glass testi-card" style="min-height: auto; padding-bottom: 36px;">
          <span class="accent-bar" style="margin-bottom: 22px;"></span>
          <p style="font-weight: 300; font-size: 1.05rem; line-height: 1.7; color: var(--muted-stronger); font-style: italic; flex: 1 1 auto; margin: 0 0 28px 0;">
            "{t1.q}"
          </p>
          <div style="margin-top: auto; padding-top: 20px; border-top: 1px solid var(--hairline); display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px;">
            <div>
              <div class="font-heading" style="font-size: 1.2rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--fg);">{t1.n}</div>
              <div style="font-size: 0.74rem; color: var(--soft-text); font-weight: 300; margin-top: 4px;">{t1.r}</div>
            </div>
            <div style="display: inline-flex; gap: 14px; align-items: center;">
              <div style="font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--accent);">{t1.metric?.value}</div>
              <div style="font-size: 0.62rem; letter-spacing: 0.2em; color: var(--soft-text); text-transform: uppercase;">{t1.metric?.label}</div>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal-hidden delay-1">
        <div class="liquid-glass testi-card" style="min-height: auto; padding-bottom: 36px;">
          <span class="accent-bar muted" style="margin-bottom: 22px;"></span>
          <p style="font-weight: 300; font-size: 0.95rem; line-height: 1.7; color: var(--muted-stronger); font-style: italic; flex: 1 1 auto; margin: 0 0 24px 0;">
            "{t2.q}"
          </p>
          <div style="margin-top: auto; padding-top: 20px; border-top: 1px solid var(--hairline);">
            <div class="font-heading" style="font-size: 1.1rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--fg);">{t2.n}</div>
            <div style="font-size: 0.72rem; color: var(--soft-text); font-weight: 300; margin-top: 4px;">{t2.r}</div>
          </div>
        </div>
      </div>
    </div>

    <div class="reveal-hidden delay-2">
      <div class="featured-quote">
        {t3.q}
        <div style="margin-top: 32px; font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); font-family: 'Inter Variable', 'Inter', sans-serif; font-weight: 500;">
          — {t3.n} <span style="color: var(--soft-text);">· {t3.r}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testi-grid {
    display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 56px;
  }
  @media (max-width: 880px) { .testi-grid { grid-template-columns: 1fr; } }

  .testi-card { border-radius: 24px; padding: 36px; display: flex; flex-direction: column; height: 100%; }
  
  .featured-quote {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.7rem, 3.6vw, 2.6rem);
    line-height: 1.2; letter-spacing: 0.01em;
    text-align: center; max-width: 920px; margin: 0 auto;
    color: var(--fg); position: relative; padding: 0 60px;
  }
  .featured-quote::before, .featured-quote::after {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 5rem; color: var(--accent); opacity: 0.3;
    position: absolute; line-height: 0.6;
  }
  .featured-quote::before { content: "\""; left: 0; top: 0; }
  .featured-quote::after { content: "\""; right: 0; bottom: -0.2em; }
  @media (max-width: 600px) {
    .featured-quote { padding: 0 24px; }
    .featured-quote::before, .featured-quote::after { font-size: 3rem; }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('reveal-visible');
        entry.target.classList.remove('reveal-hidden');
      }
    });
  }, { threshold: 0.05, rootMargin: '0px 0px 50px 0px' });
  
  document.querySelectorAll('.reveal-hidden').forEach(el => observer.observe(el));
</script>
