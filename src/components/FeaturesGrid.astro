---
const features = [
  {
    titulo: 'Producción Audiovisual',
    texto: 'Video, fotografía y contenido que comunican tu marca con claridad y estilo. Contenido que dispara tu engagement.',
    icon: 'video',
  },
  {
    titulo: 'Marketing Digital',
    texto: 'Estrategias de crecimiento en redes sociales, Google y email que generan resultados reales, no solo likes.',
    icon: 'barchart',
  },
  {
    titulo: 'Sistemas Web',
    texto: 'Sitios y plataformas que convierten visitantes en clientes. Rápidos, funcionales y diseñados para vender.',
    icon: 'globe',
  },
  {
    titulo: 'Diseño & Marca',
    texto: 'Identidad visual, branding y UI/UX que comunican quién sos. Del logo a la experiencia completa del usuario.',
    icon: 'layers',
  },
  {
    titulo: 'Automatización',
    texto: 'Sistemas que trabajan por vos las 24 horas. CRMs, flujos automáticos y herramientas que ahorran tiempo y dinero.',
    icon: 'settings',
  },
  {
    titulo: 'SEO & Posicionamiento',
    texto: 'Aparecer primero en Google cuando tus clientes te buscan. Tráfico orgánico que crece mes a mes.',
    icon: 'search',
  },
];
---
<section class="bg-background py-24 md:py-32">
  <div class="max-w-3xl mx-auto text-center mb-16 px-6">
    <div class="liquid-glass rounded-full px-4 py-1.5 inline-flex items-center mb-5">
      <span class="text-xs font-body font-semibold tracking-[0.2em] uppercase text-[#e87722]">LO QUE HACEMOS</span>
    </div>
    <h2 class="font-heading text-3xl md:text-5xl text-white uppercase tracking-wide mb-4 text-balance">TODO LO QUE TU NEGOCIO NECESITA</h2>
    <p class="font-body font-light text-base text-white/55 leading-relaxed">
      Servicios integrados para que tu marca crezca de forma consistente y medible.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 max-w-6xl mx-auto px-6">
    {features.map((feature, i) => (
      <div
        data-animate
        class="liquid-glass rounded-2xl p-6 md:p-8"
        style={`transition-delay: ${i * 0.10}s`}
      >
        <div class="liquid-glass-strong rounded-full w-10 h-10 flex items-center justify-center">
          {feature.icon === 'globe' && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e87722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          )}
          {feature.icon === 'barchart' && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e87722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="20" x2="18" y2="10"/>
              <line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
          )}
          {feature.icon === 'video' && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e87722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="23 7 16 12 23 17 23 7"/>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
            </svg>
          )}
          {feature.icon === 'settings' && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e87722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          )}
          {feature.icon === 'search' && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e87722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          )}
          {feature.icon === 'layers' && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e87722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="12 2 2 7 12 12 22 7 12 2"/>
              <polyline points="2 17 12 22 22 17"/>
              <polyline points="2 12 12 17 22 12"/>
            </svg>
          )}
        </div>
        <h3 class="font-heading text-xl md:text-2xl mt-5 mb-3 text-white uppercase tracking-wide">{feature.titulo}</h3>
        <p class="font-body font-light text-sm text-white/55 leading-relaxed">{feature.texto}</p>
      </div>
    ))}
  </div>
</section>
